+      {type: 'input_image', image_url: dataUrl(front.buffer), detail: 'high'},
+      {type: 'input_text', text: 'Image 2 is BACK.'},
+      {type: 'input_image', image_url: dataUrl(back.buffer), detail: 'high'},
+    ],
+  }];
