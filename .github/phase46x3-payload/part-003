+  signal?.addEventListener?.('abort', abort, {once: true});
+  try {
+    const response = await fetch(product.sourceUrl, {
+      method: 'GET',
+      redirect: 'follow',
+      signal: controller.signal,
+      headers: {'user-agent': 'RunyanGarden/0.20.3 product verification'},
