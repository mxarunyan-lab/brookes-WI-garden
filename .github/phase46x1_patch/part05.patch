name="regionalGuidance" draft={draft} onChange={updateField}/><PacketField label="Warnings" name="packetWarnings" draft={draft} onChange={updateField}/><PacketField label="Treatment information" name="treatmentInformation" draft={draft} onChange={updateField}/><PacketField label="Seed-saving restrictions" name="seedSavingRestrictions" draft={draft} onChange={updateField}/><PacketField label="Special care" name="specialCare" draft={draft} onChange={updateField}/></div></details><PacketField label="Packet notes" name="notes" draft={draft} onChange={updateField}><textarea id="packet-notes" rows="3" value={draft.notes} onChange={event=>updateField('notes',event.target.value)} placeholder="Manufacturer notes or anything you want to remember"/></PacketField>{saveError&&<p className="packet-save-error" role="alert"><AlertTriangle/>{saveError}<button type="button" onClick={()=>setSaveError('')}>Keep editing</button></p>}{savedPacket&&<p className="packet-save-success" role="status"><CheckCircle2/>Packet saved. It is visible below.</p>}<div className="packet-save-actions"><button className="primary-button" type="submit" disabled={saving}>{saving?<><RefreshCw className="is-spinning"/>Saving packet…</>:<><Check/>Save packet</>}</button><button type="button" onClick={resetForm}>Clear draft</button></div></form><section className="saved-packets" ref={savedSection}><div className="section-row"><div><span className="section-kicker">SAVED PACKETS</span><h2>{packets.length} packet{packets.length===1?'':'s'} saved</h2></div></div>{packets.length?packets.map(packet=>{const available=Math.max(0,(Number(packet.quantity)||0)-(Number(packet.reservedQuantity)||0)),preview=packet.frontPhoto||packet.photo||packet.backPhoto;return <article key={packet.id} data-packet-id={packet.id} tabIndex="-1" className={savedPacket?.id===packet.id?'is-newly-saved':''}>{preview?<img src={preview} alt={`${packet.name} seed packet`}/>:<div className="packet-placeholder"><Tags/></div>}<span><strong>{packet.name}{packet.variety?` — ${packet.variety}`:''}</strong><small>{packet.brand||'Brand not entered'} · packet {packet.packetYear||'year unknown'}</small><small>{packet.packetWeight?`${packet.packetWeight} · `:''}{available} available · {packet.reservedQuantity||0} reserved · {packet.countType||'estimated'} count</small><small>{packet.daysToMaturity?`${packet.daysToMaturity} days to maturity${packet.maturityBasis?` from ${String(packet.maturityBasis).replace(/^from\s+/i,'')}`:''}`:'Maturity not entered'}</small>{packet.frontPhoto&&packet.backPhoto&&<small>Front and back photos saved</small>}</span><button onClick={()=>deletePacket(packet.id)} aria-label={`Remove ${packet.name} packet`}><X/>Remove</button></article>}):<div className="empty-memory"><Camera/><span><strong>No packet photos yet.</strong><small>Add the first packet above.</small></span></div>}</section></section></main>;
